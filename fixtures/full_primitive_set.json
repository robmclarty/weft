{
  "version": 1,
  "root": {
    "kind": "sequence",
    "id": "seq:everything",
    "children": [
      {
        "kind": "scope",
        "id": "scope:root",
        "children": [
          {
            "kind": "stash",
            "id": "stash:greeting",
            "config": {
              "key": "greeting"
            },
            "children": [
              {
                "kind": "step",
                "id": "step:hello",
                "config": {
                  "fn": { "kind": "<fn>", "name": "hello" }
                }
              }
            ]
          },
          {
            "kind": "pipe",
            "id": "pipe:upper",
            "config": {
              "fn": { "kind": "<fn>", "name": "to_upper" }
            },
            "children": [
              {
                "kind": "use",
                "id": "use:greeting",
                "config": {
                  "keys": ["greeting"]
                },
                "children": [
                  {
                    "kind": "step",
                    "id": "step:format",
                    "config": {
                      "fn": { "kind": "<fn>", "name": "format" }
                    }
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "kind": "retry",
        "id": "retry:flaky",
        "config": {
          "max_attempts": 3,
          "backoff_ms": 250
        },
        "children": [
          {
            "kind": "step",
            "id": "step:flaky",
            "config": {
              "fn": { "kind": "<fn>", "name": "flaky" }
            }
          }
        ]
      },
      {
        "kind": "parallel",
        "id": "par:report",
        "config": {
          "keys": ["summary", "details"]
        },
        "children": [
          {
            "kind": "step",
            "id": "step:summary",
            "config": {
              "fn": { "kind": "<fn>", "name": "summarize" }
            }
          },
          {
            "kind": "step",
            "id": "step:details",
            "config": {
              "fn": { "kind": "<fn>", "name": "detail" }
            }
          }
        ]
      }
    ]
  }
}
