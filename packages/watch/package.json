    "weft-watch": "./dist/bin.js"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "dependencies": {
    "chokidar": "4.0.3",
    "commander": "13.0.0",
    "ws": "8.18.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/ws": "8.5.13"
  }
}
