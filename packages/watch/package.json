{
  "name": "@repo/watch",
  "version": "0.1.8",
  "description": "Watch CLI for weft. Tails a fascicle FlowNode JSON file and pushes changes over a localhost WebSocket.",
  "license": "Apache-2.0",
  "author": "Rob McLarty",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
