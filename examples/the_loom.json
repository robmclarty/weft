                                    "config": { "key": "architect_out" },
                                    "children": [
                                      {
                                        "kind": "step",
                                        "id": "p2__architect__step_record",
                                        "config": { "fn": { "kind": "<fn>", "name": "record_architect" } }
                                      }
                                    ]
                                  }
                                ]
                              }
                            ]
                          }
                        ]
                      },
                      {
                        "kind": "fallback",
                        "id": "p2__fb__judge",
                        "config": { "display_name": "judge" },
                        "children": [
                          {
                            "kind": "step",
                            "id": "p2__step__consensus_vote",
                            "config": { "fn": { "kind": "<fn>", "name": "consensus_vote" } }
                          },
                          {
                            "kind": "step",
                            "id": "p2__step__majority_vote",
                            "config": { "fn": { "kind": "<fn>", "name": "majority_vote" } }
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "kind": "branch",
                    "id": "p2__guard",
                    "config": {
                      "when": { "kind": "<fn>", "name": "is_improving" },
                      "display_name": "improving?"
                    },
                    "children": [
                      {
                        "kind": "step",
                        "id": "p2__step__continue_round",
                        "config": { "fn": { "kind": "<fn>", "name": "continue_round" } }
                      },
                      {
                        "kind": "step",
                        "id": "p2__step__seal_winner",
                        "config": { "fn": { "kind": "<fn>", "name": "seal_winner" } }
                      }
                    ]
                  }
                ]
              }
            ]
