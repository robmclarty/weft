                                    "kind": "step",
                                    "id": "p4__hypothesize__step_conservative",
                                    "config": { "fn": { "kind": "<fn>", "name": "h_conservative" } }
                                  },
                                  {
                                    "kind": "step",
                                    "id": "p4__hypothesize__step_contrarian",
                                    "config": { "fn": { "kind": "<fn>", "name": "h_contrarian" } }
                                  }
                                ]
                              }
                            ]
                          },
                          {
                            "kind": "compose",
