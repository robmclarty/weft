{
  "version": 1,
  "root": {
    "kind": "compose",
    "id": "the_loom",
    "config": { "display_name": "The Loom" },
    "meta": {
      "display_name": "The Loom",
      "description": "A multi-agent research engine — every primitive, woven into one circuit."
    },
    "children": [
      {
        "kind": "sequence",
        "id": "spine",
        "children": [

          {
            "kind": "compose",
            "id": "p1__ingest",
            "config": { "display_name": "Ingestion Lattice" },
            "children": [
              {
                "kind": "sequence",
                "id": "p1__seq",
                "children": [
                  {
                    "kind": "checkpoint",
                    "id": "p1__checkpoint__raw_query",
                    "config": { "key": "raw_query", "display_name": "cache_input" },
                    "children": [
                      {
                        "kind": "step",
                        "id": "p1__step__fetch_query",
                        "config": { "fn": { "kind": "<fn>", "name": "ingest" } }
                      }
                    ]
                  },
                  {
                    "kind": "scope",
                    "id": "p1__scope",
                    "children": [
                      {
                        "kind": "stash",
                        "id": "p1__stash__query",
                        "config": { "key": "query" },
                        "children": [
                          {
                            "kind": "step",
                            "id": "p1__step__normalize",
                            "config": { "fn": { "kind": "<fn>", "name": "normalize" } }
                          }
                        ]
                      },
                      {
                        "kind": "parallel",
                        "id": "p1__par__search",
                        "config": { "keys": ["broad", "deep", "exact"] },
                        "children": [
                          {
                            "kind": "retry",
                            "id": "p1__retry__broad",
                            "config": { "max_attempts": 3, "backoff_ms": 250 },
                            "children": [
                              {
                                "kind": "timeout",
                                "id": "p1__timeout__broad",
                                "config": { "ms": 6000 },
                                "children": [
                                  {
                                    "kind": "step",
                                    "id": "p1__step__search_broad",
                                    "config": { "fn": { "kind": "<fn>", "name": "search_broad" } }
                                  }
                                ]
                              }
                            ]
                          },
                          {
                            "kind": "retry",
                            "id": "p1__retry__deep",
                            "config": { "max_attempts": 5, "backoff_ms": 500 },
                            "children": [
                              {
                                "kind": "timeout",
                                "id": "p1__timeout__deep",
                                "config": { "ms": 12000 },
                                "children": [
                                  {
                                    "kind": "map",
                                    "id": "p1__map__urls",
                                    "config": {
                                      "items": { "kind": "<fn>", "name": "urls" },
                                      "concurrency": 4
                                    },
                                    "children": [
                                      {
                                        "kind": "step",
                                        "id": "p1__step__crawl_deep",
                                        "config": { "fn": { "kind": "<fn>", "name": "crawl_deep" } }
                                      }
                                    ]
                                  }
                                ]
                              }
                            ]
                          },
                          {
                            "kind": "pipe",
                            "id": "p1__pipe__normalize_url",
                            "config": { "fn": { "kind": "<fn>", "name": "normalize_url" } },
                            "children": [
                              {
                                "kind": "step",
                                "id": "p1__step__search_exact",
                                "config": { "fn": { "kind": "<fn>", "name": "search_exact" } }
                              }
                            ]
                          }
                        ]
                      },
                      {
                        "kind": "stash",
                        "id": "p1__stash__candidates",
                        "config": { "key": "candidates" },
                        "children": [
                          {
                            "kind": "step",
                            "id": "p1__step__merge_dedupe",
                            "config": { "fn": { "kind": "<fn>", "name": "merge_dedupe" } }
                          }
                        ]
                      },
                      {
                        "kind": "use",
                        "id": "p1__use__filter",
                        "config": { "keys": ["query", "candidates"] },
                        "children": [
                          {
                            "kind": "step",
                            "id": "p1__step__filter_relevant",
                            "config": { "fn": { "kind": "<fn>", "name": "filter_relevant" } }
                          }
                        ]
                      }
                    ]
                  }
                ]
              }
            ]
          },

          {
