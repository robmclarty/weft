            "id": "p2__tournament",
            "config": { "display_name": "Ensemble Tournament" },
            "children": [
              {
                "kind": "loop",
                "id": "p2__loop",
                "config": { "max_rounds": 5, "display_name": "tournament_rounds" },
                "children": [
                  {
                    "kind": "sequence",
                    "id": "p2__loop_body",
                    "children": [
                      {
                        "kind": "parallel",
                        "id": "p2__par__agents",
                        "config": { "keys": ["critic", "oracle", "curator", "architect"] },
                        "children": [
                          {
                            "kind": "compose",
                            "id": "p2__agent_critic",
                            "config": { "display_name": "critic" },
                            "children": [
                              {
                                "kind": "sequence",
                                "id": "p2__critic__seq",
                                "children": [
                                  {
                                    "kind": "timeout",
                                    "id": "p2__critic__timeout",
                                    "config": { "ms": 8000 },
                                    "children": [
                                      {
                                        "kind": "step",
                                        "id": "p2__critic__step_think",
                                        "config": { "fn": { "kind": "<fn>", "name": "think_critic" } }
                                      }
                                    ]
                                  },
                                  {
                                    "kind": "retry",
                                    "id": "p2__critic__retry",
                                    "config": { "max_attempts": 3, "backoff_ms": 200 },
                                    "children": [
                                      {
                                        "kind": "step",
                                        "id": "p2__critic__step_critique",
                                        "config": { "fn": { "kind": "<fn>", "name": "critique" } }
                                      }
                                    ]
                                  },
                                  {
                                    "kind": "pipe",
                                    "id": "p2__critic__pipe",
                                    "config": { "fn": { "kind": "<fn>", "name": "format_md" } },
                                    "children": [
                                      {
                                        "kind": "step",
                                        "id": "p2__critic__step_emit",
                                        "config": { "fn": { "kind": "<fn>", "name": "emit_critic" } }
                                      }
                                    ]
                                  },
                                  {
                                    "kind": "checkpoint",
                                    "id": "p2__critic__checkpoint",
                                    "config": { "key": "critic_out" },
                                    "children": [
                                      {
                                        "kind": "step",
                                        "id": "p2__critic__step_record",
                                        "config": { "fn": { "kind": "<fn>", "name": "record_critic" } }
                                      }
                                    ]
                                  }
                                ]
                              }
                            ]
                          },
                          {
                            "kind": "compose",
                            "id": "p2__agent_oracle",
                            "config": { "display_name": "oracle" },
                            "children": [
                              {
                                "kind": "sequence",
                                "id": "p2__oracle__seq",
                                "children": [
                                  {
                                    "kind": "timeout",
                                    "id": "p2__oracle__timeout",
                                    "config": { "ms": 8000 },
                                    "children": [
                                      {
                                        "kind": "step",
                                        "id": "p2__oracle__step_think",
                                        "config": { "fn": { "kind": "<fn>", "name": "think_oracle" } }
                                      }
                                    ]
                                  },
                                  {
                                    "kind": "retry",
                                    "id": "p2__oracle__retry",
                                    "config": { "max_attempts": 3, "backoff_ms": 200 },
                                    "children": [
                                      {
                                        "kind": "step",
                                        "id": "p2__oracle__step_predict",
                                        "config": { "fn": { "kind": "<fn>", "name": "predict" } }
                                      }
                                    ]
                                  },
                                  {
                                    "kind": "pipe",
                                    "id": "p2__oracle__pipe",
                                    "config": { "fn": { "kind": "<fn>", "name": "format_md" } },
                                    "children": [
                                      {
                                        "kind": "step",
                                        "id": "p2__oracle__step_emit",
                                        "config": { "fn": { "kind": "<fn>", "name": "emit_oracle" } }
                                      }
                                    ]
                                  },
                                  {
                                    "kind": "checkpoint",
                                    "id": "p2__oracle__checkpoint",
                                    "config": { "key": "oracle_out" },
                                    "children": [
                                      {
                                        "kind": "step",
                                        "id": "p2__oracle__step_record",
                                        "config": { "fn": { "kind": "<fn>", "name": "record_oracle" } }
                                      }
                                    ]
                                  }
                                ]
                              }
                            ]
                          },
                          {
                            "kind": "compose",
                            "id": "p2__agent_curator",
                            "config": { "display_name": "curator" },
                            "children": [
                              {
                                "kind": "sequence",
                                "id": "p2__curator__seq",
                                "children": [
                                  {
                                    "kind": "timeout",
                                    "id": "p2__curator__timeout",
                                    "config": { "ms": 8000 },
                                    "children": [
                                      {
                                        "kind": "step",
                                        "id": "p2__curator__step_think",
                                        "config": { "fn": { "kind": "<fn>", "name": "think_curator" } }
                                      }
                                    ]
                                  },
                                  {
                                    "kind": "retry",
                                    "id": "p2__curator__retry",
                                    "config": { "max_attempts": 3, "backoff_ms": 200 },
                                    "children": [
                                      {
                                        "kind": "step",
                                        "id": "p2__curator__step_curate",
                                        "config": { "fn": { "kind": "<fn>", "name": "curate" } }
                                      }
                                    ]
                                  },
                                  {
                                    "kind": "pipe",
                                    "id": "p2__curator__pipe",
                                    "config": { "fn": { "kind": "<fn>", "name": "format_md" } },
                                    "children": [
                                      {
                                        "kind": "step",
                                        "id": "p2__curator__step_emit",
                                        "config": { "fn": { "kind": "<fn>", "name": "emit_curator" } }
                                      }
                                    ]
                                  },
                                  {
                                    "kind": "checkpoint",
                                    "id": "p2__curator__checkpoint",
                                    "config": { "key": "curator_out" },
                                    "children": [
                                      {
                                        "kind": "step",
                                        "id": "p2__curator__step_record",
                                        "config": { "fn": { "kind": "<fn>", "name": "record_curator" } }
                                      }
                                    ]
                                  }
                                ]
                              }
                            ]
                          },
                          {
                            "kind": "compose",
                            "id": "p2__agent_architect",
                            "config": { "display_name": "architect" },
                            "children": [
                              {
                                "kind": "sequence",
                                "id": "p2__architect__seq",
                                "children": [
                                  {
                                    "kind": "timeout",
                                    "id": "p2__architect__timeout",
                                    "config": { "ms": 8000 },
                                    "children": [
                                      {
                                        "kind": "step",
                                        "id": "p2__architect__step_think",
                                        "config": { "fn": { "kind": "<fn>", "name": "think_architect" } }
                                      }
                                    ]
                                  },
                                  {
                                    "kind": "retry",
                                    "id": "p2__architect__retry",
                                    "config": { "max_attempts": 3, "backoff_ms": 200 },
