                "kind": "scope",
                "id": "p5__scope",
                "children": [
                  {
                    "kind": "stash",
                    "id": "p5__stash__best",
                    "config": { "key": "best" },
                    "children": [
                      {
                        "kind": "step",
                        "id": "p5__step__pick_best",
                        "config": { "fn": { "kind": "<fn>", "name": "pick_best" } }
                      }
                    ]
                  },
                  {
                    "kind": "parallel",
                    "id": "p5__par__writers",
                    "config": { "keys": ["outline", "intro", "body", "conclusion"] },
                    "children": [
                      {
                        "kind": "pipe",
                        "id": "p5__pipe__outline",
                        "config": { "fn": { "kind": "<fn>", "name": "plan" } },
                        "children": [
                          {
                            "kind": "step",
                            "id": "p5__step__write_outline",
                            "config": { "fn": { "kind": "<fn>", "name": "write_outline" } }
                          }
                        ]
                      },
                      {
                        "kind": "pipe",
                        "id": "p5__pipe__intro",
                        "config": { "fn": { "kind": "<fn>", "name": "hook" } },
                        "children": [
                          {
                            "kind": "step",
                            "id": "p5__step__write_intro",
                            "config": { "fn": { "kind": "<fn>", "name": "write_intro" } }
                          }
                        ]
                      },
                      {
                        "kind": "map",
                        "id": "p5__map__body",
                        "config": {
                          "items": { "kind": "<fn>", "name": "sections" },
                          "concurrency": 3
                        },
                        "children": [
                          {
                            "kind": "step",
                            "id": "p5__step__write_body",
                            "config": { "fn": { "kind": "<fn>", "name": "write_body" } }
                          }
                        ]
                      },
                      {
                        "kind": "pipe",
                        "id": "p5__pipe__conclusion",
                        "config": { "fn": { "kind": "<fn>", "name": "close" } },
                        "children": [
                          {
                            "kind": "step",
                            "id": "p5__step__write_conclusion",
                            "config": { "fn": { "kind": "<fn>", "name": "write_conclusion" } }
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "kind": "use",
                    "id": "p5__use__weave",
                    "config": {
                      "keys": ["query", "candidates", "findings", "best", "round_log"]
                    },
                    "children": [
                      {
                        "kind": "fallback",
                        "id": "p5__fb__combine",
                        "config": { "display_name": "combine" },
                        "children": [
                          {
                            "kind": "step",
                            "id": "p5__step__weave",
                            "config": { "fn": { "kind": "<fn>", "name": "weave" } }
                          },
                          {
                            "kind": "step",
                            "id": "p5__step__concat",
                            "config": { "fn": { "kind": "<fn>", "name": "concat" } }
                          }
                        ]
                      }
                    ]
                  }
                ]
              }
            ]
          },

          {
            "kind": "branch",
            "id": "p6__branch__validate",
            "config": {
              "when": { "kind": "<fn>", "name": "quality_pass" },
              "display_name": "validate"
            },
            "children": [
              {
                "kind": "step",
                "id": "p6__step__approve",
                "config": { "fn": { "kind": "<fn>", "name": "approve" } }
              },
              {
                "kind": "retry",
                "id": "p6__retry__revise",
                "config": { "max_attempts": 2, "backoff_ms": 500 },
                "children": [
                  {
                    "kind": "step",
                    "id": "p6__step__revise",
                    "config": { "fn": { "kind": "<fn>", "name": "revise" } }
                  }
                ]
              }
            ]
          },

          {
            "kind": "suspend",
            "id": "p7__suspend__ship_review",
            "config": { "id": "ship_review" },
            "meta": {
              "display_name": "Human Approval",
              "description": "Pause for human review before publishing."
            }
          },

          {
            "kind": "parallel",
            "id": "p8__par__publish",
            "config": { "keys": ["markdown", "html", "json", "slides"] },
            "children": [
              {
                "kind": "pipe",
                "id": "p8__pipe__md",
                "config": { "fn": { "kind": "<fn>", "name": "to_md" } },
                "children": [
                  {
                    "kind": "step",
                    "id": "p8__step__emit_md",
                    "config": { "fn": { "kind": "<fn>", "name": "emit_md" } }
                  }
                ]
              },
              {
                "kind": "pipe",
                "id": "p8__pipe__html",
                "config": { "fn": { "kind": "<fn>", "name": "to_html" } },
                "children": [
                  {
                    "kind": "step",
                    "id": "p8__step__emit_html",
                    "config": { "fn": { "kind": "<fn>", "name": "emit_html" } }
                  }
                ]
              },
              {
                "kind": "pipe",
                "id": "p8__pipe__json",
                "config": { "fn": { "kind": "<fn>", "name": "to_json" } },
                "children": [
                  {
                    "kind": "step",
                    "id": "p8__step__emit_json",
                    "config": { "fn": { "kind": "<fn>", "name": "emit_json" } }
                  }
                ]
              },
              {
                "kind": "pipe",
                "id": "p8__pipe__slides",
                "config": { "fn": { "kind": "<fn>", "name": "to_slides" } },
                "children": [
                  {
                    "kind": "step",
                    "id": "p8__step__emit_slides",
                    "config": { "fn": { "kind": "<fn>", "name": "emit_slides" } }
                  }
                ]
              }
            ]
          }

        ]
      }
    ]
  }
