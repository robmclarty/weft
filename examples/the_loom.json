                                      }
                                    ]
                                  }
                                ]
                              }
                            ]
                          },
                          {
                            "kind": "compose",
                            "id": "p4__evaluate",
                            "config": { "display_name": "evaluate" },
                            "children": [
                              {
                                "kind": "fallback",
                                "id": "p4__evaluate__fb",
                                "config": { "display_name": "judge_eval" },
                                "children": [
                                  {
                                    "kind": "step",
                                    "id": "p4__evaluate__step_llm_judge",
                                    "config": { "fn": { "kind": "<fn>", "name": "llm_judge" } }
                                  },
                                  {
                                    "kind": "step",
                                    "id": "p4__evaluate__step_rubric_judge",
                                    "config": { "fn": { "kind": "<fn>", "name": "rubric_judge" } }
                                  }
                                ]
                              }
                            ]
                          },
                          {
                            "kind": "compose",
                            "id": "p4__refine",
                            "config": { "display_name": "refine" },
                            "children": [
                              {
                                "kind": "pipe",
                                "id": "p4__refine__pipe",
                                "config": { "fn": { "kind": "<fn>", "name": "improve_prompt" } },
                                "children": [
                                  {
                                    "kind": "step",
                                    "id": "p4__refine__step",
                                    "config": { "fn": { "kind": "<fn>", "name": "refine_step" } }
                                  }
                                ]
                              }
                            ]
                          }
                        ]
                      },
                      {
                        "kind": "scope",
                        "id": "p4__scope",
                        "children": [
                          {
                            "kind": "stash",
                            "id": "p4__stash__findings",
                            "config": { "key": "findings" },
                            "children": [
                              {
                                "kind": "step",
                                "id": "p4__step__record_findings",
                                "config": { "fn": { "kind": "<fn>", "name": "record_findings" } }
                              }
                            ]
                          },
                          {
                            "kind": "use",
                            "id": "p4__use__findings",
                            "config": { "keys": ["findings"] },
                            "children": [
                              {
                                "kind": "step",
                                "id": "p4__step__distill_findings",
                                "config": { "fn": { "kind": "<fn>", "name": "distill_findings" } }
                              }
                            ]
                          }
                        ]
                      }
                    ]
                  }
                ]
              }
            ]
          },

          {
            "kind": "compose",
