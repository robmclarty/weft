                            "config": { "display_name": "experiment" },
                            "children": [
                              {
                                "kind": "map",
                                "id": "p4__experiment__map",
                                "config": {
                                  "items": { "kind": "<fn>", "name": "experiments" },
                                  "concurrency": 4
