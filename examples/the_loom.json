            "children": [
              {
                "kind": "loop",
                "id": "p3__loop",
                "config": { "max_rounds": 8, "display_name": "red_vs_blue" },
                "children": [
                  {
                    "kind": "sequence",
                    "id": "p3__loop_body",
                    "children": [
                      {
                        "kind": "parallel",
                        "id": "p3__par__teams",
                        "config": { "keys": ["red_team", "blue_team"] },
                        "children": [
                          {
                            "kind": "compose",
                            "id": "p3__red",
                            "config": { "display_name": "red team" },
                            "children": [
                              {
                                "kind": "parallel",
                                "id": "p3__red__par",
                                "config": { "keys": ["propose", "attack", "defend"] },
                                "children": [
                                  {
                                    "kind": "retry",
                                    "id": "p3__red__retry__propose",
                                    "config": { "max_attempts": 3, "backoff_ms": 100 },
                                    "children": [
                                      {
                                        "kind": "step",
                                        "id": "p3__red__step__propose",
                                        "config": { "fn": { "kind": "<fn>", "name": "red_propose" } }
                                      }
                                    ]
                                  },
                                  {
                                    "kind": "timeout",
                                    "id": "p3__red__timeout__attack",
                                    "config": { "ms": 4000 },
                                    "children": [
                                      {
                                        "kind": "step",
                                        "id": "p3__red__step__attack",
                                        "config": { "fn": { "kind": "<fn>", "name": "red_attack" } }
                                      }
                                    ]
                                  },
                                  {
                                    "kind": "pipe",
                                    "id": "p3__red__pipe__defend",
                                    "config": { "fn": { "kind": "<fn>", "name": "harden" } },
                                    "children": [
                                      {
                                        "kind": "step",
                                        "id": "p3__red__step__defend",
                                        "config": { "fn": { "kind": "<fn>", "name": "red_defend" } }
                                      }
                                    ]
                                  }
                                ]
                              }
                            ]
                          },
                          {
                            "kind": "compose",
                            "id": "p3__blue",
                            "config": { "display_name": "blue team" },
                            "children": [
                              {
                                "kind": "parallel",
                                "id": "p3__blue__par",
                                "config": { "keys": ["propose", "attack", "defend"] },
                                "children": [
                                  {
                                    "kind": "retry",
                                    "id": "p3__blue__retry__propose",
                                    "config": { "max_attempts": 3, "backoff_ms": 100 },
                                    "children": [
                                      {
                                        "kind": "step",
                                        "id": "p3__blue__step__propose",
                                        "config": { "fn": { "kind": "<fn>", "name": "blue_propose" } }
                                      }
                                    ]
                                  },
                                  {
                                    "kind": "timeout",
                                    "id": "p3__blue__timeout__attack",
                                    "config": { "ms": 4000 },
                                    "children": [
                                      {
                                        "kind": "step",
                                        "id": "p3__blue__step__attack",
                                        "config": { "fn": { "kind": "<fn>", "name": "blue_attack" } }
                                      }
                                    ]
                                  },
                                  {
                                    "kind": "pipe",
                                    "id": "p3__blue__pipe__defend",
                                    "config": { "fn": { "kind": "<fn>", "name": "harden" } },
                                    "children": [
                                      {
                                        "kind": "step",
                                        "id": "p3__blue__step__defend",
                                        "config": { "fn": { "kind": "<fn>", "name": "blue_defend" } }
                                      }
                                    ]
                                  }
                                ]
                              }
                            ]
                          }
                        ]
                      },
                      {
                        "kind": "fallback",
                        "id": "p3__fb__resolve",
                        "config": { "display_name": "resolve" },
                        "children": [
                          {
                            "kind": "step",
                            "id": "p3__step__consensus_resolve",
                            "config": { "fn": { "kind": "<fn>", "name": "consensus_resolve" } }
                          },
                          {
                            "kind": "step",
                            "id": "p3__step__arbitrate",
                            "config": { "fn": { "kind": "<fn>", "name": "arbitrate" } }
                          }
                        ]
                      },
                      {
                        "kind": "scope",
                        "id": "p3__scope",
                        "children": [
                          {
                            "kind": "stash",
                            "id": "p3__stash__round_log",
                            "config": { "key": "round_log" },
                            "children": [
                              {
                                "kind": "step",
                                "id": "p3__step__log_round",
                                "config": { "fn": { "kind": "<fn>", "name": "log_round" } }
                              }
                            ]
                          },
                          {
                            "kind": "use",
                            "id": "p3__use__round_log",
                            "config": { "keys": ["round_log"] },
                            "children": [
                              {
                                "kind": "branch",
                                "id": "p3__branch__converged",
                                "config": {
                                  "when": { "kind": "<fn>", "name": "converged" },
                                  "display_name": "converged?"
                                },
                                "children": [
                                  {
                                    "kind": "step",
                                    "id": "p3__step__stabilize",
                                    "config": { "fn": { "kind": "<fn>", "name": "stabilize" } }
                                  },
                                  {
                                    "kind": "step",
                                    "id": "p3__step__escalate",
                                    "config": { "fn": { "kind": "<fn>", "name": "escalate" } }
                                  }
                                ]
                              }
                            ]
                          }
                        ]
                      }
                    ]
                  }
                ]
              }
            ]
          },

          {
            "kind": "compose",
            "id": "p4__meta_research",
            "config": { "display_name": "Self-Improving Meta-Research" },
            "children": [
              {
                "kind": "loop",
                "id": "p4__loop",
                "config": { "max_rounds": 4, "display_name": "meta_rounds" },
                "children": [
                  {
                    "kind": "sequence",
                    "id": "p4__loop_body",
                    "children": [
