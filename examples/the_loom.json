                                      {
                                        "kind": "step",
                                        "id": "p2__architect__step_design",
                                        "config": { "fn": { "kind": "<fn>", "name": "design" } }
                                      }
                                    ]
                                  },
                                  {
                                    "kind": "pipe",
                                    "id": "p2__architect__pipe",
                                    "config": { "fn": { "kind": "<fn>", "name": "format_md" } },
                                    "children": [
                                      {
                                        "kind": "step",
