{
  "name": "@robmclarty/weft",
  "version": "0.1.0",
  "description": "UI for Fascicle",
  "license": "Apache-2.0",
  "author": "Rob McLarty",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "check": "node scripts/check.mjs",
    "check:all": "node scripts/check.mjs --all",
    "check:json": "node scripts/check.mjs --json",
    "check:bail": "node scripts/check.mjs --bail",
    "check:fix": "pnpm exec oxlint --type-aware --fix && pnpm exec fallow fix",
    "check:mutation": "stryker run",
    "check:security": "pnpm audit --audit-level=high",
    "test": "vitest run",
    "test:watch": "vitest",
    "types": "tsc --noEmit"
  },
  "devDependencies": {
    "@ast-grep/cli": "0.42.1",
    "@stryker-mutator/core": "9.6.1",
    "@stryker-mutator/vitest-runner": "9.6.1",
    "@types/node": "24.12.2",
    "@vitest/coverage-v8": "4.1.5",
    "cspell": "10.0.0",
    "fallow": "2.48.0",
    "markdownlint-cli2": "0.22.1",
    "oxlint": "1.61.0",
    "oxlint-tsgolint": "0.21.1",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  }
}
